# -----------------------------------------------------------------------------
# REQUIRED — Postgres credentials used by docker-compose.
# From repo root run:  python scripts/ensure_dotenv.py
# (replaces this placeholder with a random password in ../.env when needed).
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=change-me-use-openssl-rand-base64-32
# POSTGRES_USER=freeai
# POSTGRES_DB=freeai

# -----------------------------------------------------------------------------
# REQUIRED when running the `observability` compose profile (Grafana).
# -----------------------------------------------------------------------------
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=change-me

# -----------------------------------------------------------------------------
# Optional — omit FREEAI_MASTER_KEY on first install: server prints a generated
# key to stdout; paste it in the UI (then optional FREEAI_MASTER_KEY is written
# to this .env automatically). Provider keys in the UI are encrypted with it.
# -----------------------------------------------------------------------------
# FREEAI_MASTER_KEY=
# FREEAI_ADMIN_TOKEN=   # optional; if unset, use JWT first-user registration
# FREEAI_LEGACY_INITIAL_SETUP=true   # optional; restore legacy admin-token wizard
# FREEAI_JWT_SECRET=

# CORS — comma-separated origins allowed to call the API from a browser.
# Add your production domain/IP here. Include HTTPS if using a reverse proxy.
# Default: http://localhost:8000,http://127.0.0.1:8000
# FREEAI_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://your-domain.example.com

# Optional env fallbacks — same keys as in the control panel.
# All variables use the FREEAI_ prefix (pydantic-settings reads them automatically).
FREEAI_GROQ_API_KEY=
FREEAI_GEMINI_API_KEY=
FREEAI_MISTRAL_API_KEY=
FREEAI_OPENROUTER_API_KEY=
FREEAI_COHERE_API_KEY=
FREEAI_HF_API_KEY=
